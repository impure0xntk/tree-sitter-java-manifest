{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "java_manifest_mf",
  "word": "attribute_key",
  "rules": {
    "manifest": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "main_section"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "individual_section"
          }
        }
      ]
    },
    "main_section": {
      "type": "REPEAT1",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SYMBOL",
            "name": "attribute_entry"
          },
          {
            "type": "SYMBOL",
            "name": "continuation_line"
          }
        ]
      }
    },
    "individual_section": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "section_name_header"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "attribute_entry"
              },
              {
                "type": "SYMBOL",
                "name": "continuation_line"
              }
            ]
          }
        }
      ]
    },
    "section_name_header": {
      "type": "PREC_RIGHT",
      "value": 0,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "PATTERN",
            "value": "[Nn][Aa][Mm][Ee]"
          },
          {
            "type": "STRING",
            "value": ": "
          },
          {
            "type": "FIELD",
            "name": "name",
            "content": {
              "type": "SYMBOL",
              "name": "section_name"
            }
          },
          {
            "type": "REPEAT",
            "content": {
              "type": "SYMBOL",
              "name": "section_name_continuation"
            }
          }
        ]
      }
    },
    "section_name": {
      "type": "IMMEDIATE_TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "[^\\x00\\n\\r]+"
      }
    },
    "section_name_continuation": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": " "
        },
        {
          "type": "FIELD",
          "name": "value",
          "content": {
            "type": "SYMBOL",
            "name": "continuation_value"
          }
        }
      ]
    },
    "attribute_entry": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "key",
          "content": {
            "type": "SYMBOL",
            "name": "attribute_key"
          }
        },
        {
          "type": "STRING",
          "value": ": "
        },
        {
          "type": "FIELD",
          "name": "value",
          "content": {
            "type": "SYMBOL",
            "name": "attribute_value"
          }
        }
      ]
    },
    "attribute_value": {
      "type": "IMMEDIATE_TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "[^\\x00\\n\\r]*"
      }
    },
    "continuation_line": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": " "
        },
        {
          "type": "FIELD",
          "name": "value",
          "content": {
            "type": "SYMBOL",
            "name": "continuation_value"
          }
        }
      ]
    },
    "continuation_value": {
      "type": "IMMEDIATE_TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "[^\\x00\\n\\r]*"
      }
    },
    "attribute_key": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "[A-Za-z0-9][A-Za-z0-9_\\-]*"
      }
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "[ \\t\\f]+"
    },
    {
      "type": "PATTERN",
      "value": "\\r?\\n|\\r"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}